# ============ 言课 环境变量样例 ============
# 复制为 .env 并填入真实值。切勿提交 .env。

# ---- 应用 ----
NEXT_PUBLIC_APP_NAME=言课
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- PDF 导出（Playwright）----
# 默认用环境预装的 Chromium；如路径不同可覆盖（指向 chromium 可执行文件）。
# PW_CHROMIUM_PATH=/opt/pw-browsers/chromium

# ---- 反向代理与限流 ----
# 限流取客户端 IP（clientIp，被 10 个路由复用）：默认不信任 X-Forwarded-For（可伪造）。
# 仅当上游反代会「强制重写」而非「透传」XFF 时设为 1，使限流按真实 IP 生效；否则保持关闭，
# 按 x-real-ip 取值（平台未注入则回退 anon 共享一个桶）。当前为单进程内存限流，生产应升级网关/Redis。
# TRUST_PROXY_XFF=1

# ---- 数据库（PostgreSQL）----
# 不配置时回退内存实现（本地/CI 可跑通，但数据不持久）。
DATABASE_URL=postgresql://yanke:yanke@localhost:5432/yanke?schema=public
# 托管 Postgres（Supabase/Neon/RDS 等）默认要求 TLS：
#   在连接串追加 ?sslmode=require（推荐），或设置 PGSSL=require
#   自签证书场景可用 PGSSL=no-verify（关闭证书校验，注意 MITM 风险）
# PGSSL=
# 连接池可调（默认 max=10）：PG_POOL_MAX / PG_IDLE_TIMEOUT_MS / PG_CONN_TIMEOUT_MS

# ---- 对象存储（S3 兼容；本地用 MinIO）----
S3_ENDPOINT=http://localhost:9000
S3_REGION=cn-local
S3_BUCKET=yanke
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- 鉴权（Auth.js）----
# 生产必填，经平台 secret/环境变量注入，切勿提交（openssl rand -base64 32 生成）。
#   严禁把样例占位带入生产：一旦泄漏，攻击者可伪造任意用户 JWT 会话。
#   轮换 AUTH_SECRET 会立即失效所有现存会话（用户需重新登录），应排期通告。
#   开发未配置时自动使用「每次启动随机」的临时密钥（不入库、重启即失效）。
AUTH_SECRET=change-me-with-a-random-secret
# 生产建议显式设置站点 URL，使会话/回调不依赖可伪造的 x-forwarded-proto/host：
# AUTH_URL=https://your-domain

# ---- 短信验证码（OTP）----
# 不配置 SMS_PROVIDER 时回退 mock：验证码仅打印到服务端日志，开发接口回显，便于离线自测。
# 配置后需在 src/auth/otp/sms.ts 接入服务商（阿里云/腾讯云短信等）。
# SMS_PROVIDER=aliyun
# SMS_ACCESS_KEY=
# SMS_SECRET_KEY=
# SMS_SIGN_NAME=
# SMS_TEMPLATE_ID=

# ---- LLM Provider（抽象层，按任务分级路由）----
# 默认走国产模型；可切换 gemini / Claude / OpenAI。详见 docs/04-ai-pipeline.md
# 不填任何 Key 时自动回落到离线 Mock（全流程仍可跑通，产出示例课件）。
LLM_DEFAULT_PROVIDER=deepseek   # deepseek | gemini

# 各档位模型（light=意图/大纲, standard=校验, heavy=全文）
LLM_MODEL_LIGHT=deepseek-chat
LLM_MODEL_STANDARD=deepseek-chat
LLM_MODEL_HEAVY=deepseek-chat

# Provider 密钥（按实际启用的填）
DEEPSEEK_API_KEY=
GEMINI_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
