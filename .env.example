# ============ 言课 环境变量样例 ============
# 复制为 .env 并填入真实值。切勿提交 .env。

# ---- 应用 ----
NEXT_PUBLIC_APP_NAME=言课
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ---- 数据库（PostgreSQL）----
DATABASE_URL=postgresql://yanke:yanke@localhost:5432/yanke?schema=public

# ---- 对象存储（S3 兼容；本地用 MinIO）----
S3_ENDPOINT=http://localhost:9000
S3_REGION=cn-local
S3_BUCKET=yanke
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# ---- 鉴权（Auth.js）----
AUTH_SECRET=change-me-with-a-random-secret

# ---- LLM Provider（抽象层，按任务分级路由）----
# 默认走国产模型；可切换 Claude / OpenAI。详见 docs/04-ai-pipeline.md
LLM_DEFAULT_PROVIDER=deepseek

# 各档位模型（light=意图/大纲, standard=版式/校验/精修, heavy=全文）
LLM_MODEL_LIGHT=deepseek-chat
LLM_MODEL_STANDARD=deepseek-chat
LLM_MODEL_HEAVY=deepseek-reasoner

# Provider 密钥（按实际启用的填）
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
